# 이 파일을 복사해서 ".env" 로 이름을 바꾸고 실제 값으로 채워 넣으세요.
# (.env 파일은 llm.py에서 python-dotenv로 자동으로 읽어옵니다)

# ── OpenAI 정식 API를 사용할 경우 ─────────────────────────
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-여기에-실제-키-입력
LLM_MODEL=gpt-4o-mini

# ── Ollama를 사용할 경우 (아래 주석을 해제하고 위 값 대신 사용) ──
# Ollama는 OpenAI 호환 엔드포인트(/v1)를 기본으로 제공하므로
# 코드 수정 없이 이 값만 바꾸면 됩니다.
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3

# ── LM Studio 등 다른 OpenAI 호환 로컬 서버를 사용할 경우 ──
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=사용중인-모델-이름
